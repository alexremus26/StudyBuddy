DJANGO_SECRET_KEY=change-me
DEBUG=True
DJANGO_LOGLEVEL=info
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_ENGINE=django.contrib.gis.db.backends.postgis
DATABASE_NAME=dockerdjango
DATABASE_USERNAME=studybuddy
DATABASE_PASSWORD=change-me
DATABASE_HOST=db
DATABASE_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Mapbox public access token used by the frontend map.
VITE_MAPBOX_ACCESS_TOKEN=

# Gemini Vision API configuration for advanced schedule extraction.
# Leave empty to use Hybrid OCR only (free, local, no API key required).
# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=
# Model to use for Gemini Vision extraction (default: gemini-2.0-flash).
GEMINI_MODEL=gemini-2.5-flash
# Confidence threshold for auto-escalation to Gemini (0.0-1.0, default: 0.62).
# Hybrid currently scores around 0.57-0.62, so this keeps Gemini for harder cases.
GEMINI_ESCALATION_CONFIDENCE_THRESHOLD=0.62
# Escalate only when Hybrid output is sparse (default: fewer than 4 blocks).
GEMINI_ESCALATION_MIN_BLOCKS=4

# Keep this higher than API timeout to avoid worker kill during inference.
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
