DJANGO_SECRET_KEY=change-me
DEBUG=True
DJANGO_LOGLEVEL=info
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_ENGINE=postgresql_psycopg2
DATABASE_NAME=dockerdjango
DATABASE_USERNAME=studybuddy
DATABASE_PASSWORD=change-me
DATABASE_HOST=db
DATABASE_PORT=5432

# Primary model used first; leave empty if you only want candidates.
OLLAMA_MODEL=
# Optional comma-separated fallback models (pulled at bootstrap if missing).
# Example: OLLAMA_MODEL_CANDIDATES=llama3.2:3b,mistral:7b
OLLAMA_MODEL_CANDIDATES=
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_TIMEOUT_SECONDS=90
# Per-request timeout used by parser call (keep below Gunicorn timeout).
OLLAMA_REQUEST_TIMEOUT_SECONDS=75

# LLM provider for schedule parser.
SCHEDULE_PARSER_PROVIDER=ollama

# Keep this higher than OLLAMA_TIMEOUT_SECONDS to avoid worker kill during model inference.
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
