# Django Configuration
DJANGO_SECRET_KEY=change-me
DEBUG=True
DJANGO_LOGLEVEL=info
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (PostgreSQL)
DATABASE_ENGINE=postgresql_psycopg2
DATABASE_NAME=dockerdjango
DATABASE_USERNAME=stoici
DATABASE_PASSWORD=change-me
DATABASE_HOST=db
DATABASE_PORT=5432

# API Keys - Google Services
GOOGLE_PLACES_API_KEY=change-me
GEMINI_API_KEY=change-me

# Apify Configuration
APIFY_API_TOKEN=change-me
APIFY_MAX_REVIEWS_PER_PLACE=40

# Redis & Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend Configuration
VITE_MAPBOX_ACCESS_TOKEN=change-me

# AI Model Configuration
GEMINI_MODEL=gemini-3.1-flash-lite-preview
OLLAMA_MODEL=llama3.2:3b
GEMINI_ESCALATION_CONFIDENCE_THRESHOLD=0.62
GEMINI_ESCALATION_MIN_BLOCKS=4

# Server Configuration
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
